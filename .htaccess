Options -Indexes
RewriteEngine On

# ─── Force HTTPS (http:// → https://) ──────────────────────────────────────
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# ─── Force non-www (www.japandevguide.com → japandevguide.com) ──────────────
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

# ─── Remove /index.html from homepage URL ───────────────────────────────────
RewriteCond %{THE_REQUEST} \s/index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]

# ─── 301 Redirects: old Indonesian slugs → new English slugs ───────────────

Redirect 301 /articles/bahasa-jepang-untuk-engineer.html /articles/japanese-for-engineers.html
Redirect 301 /articles/biaya-hidup-jepang.html /articles/cost-of-living-japan.html
Redirect 301 /articles/budaya-kerja-it-jepang.html /articles/it-work-culture-japan.html
Redirect 301 /articles/cara-melamar-kerja-it-jepang.html /articles/how-to-get-it-job-japan.html
Redirect 301 /articles/gaji-it-jepang.html /articles/it-salary-japan.html
Redirect 301 /articles/interview-it-jepang.html /articles/it-job-interview-japan.html
Redirect 301 /articles/karir-it-jepang.html /articles/it-career-japan.html
Redirect 301 /articles/kelebihan-tinggal-di-jepang.html /articles/why-live-in-japan-developer.html
Redirect 301 /articles/tech-stack-jepang.html /articles/tech-stack-japan.html
Redirect 301 /articles/top-perusahaan-it-jepang.html /articles/top-it-companies-japan.html
Redirect 301 /articles/visa-kerja-jepang.html /articles/it-work-visa-japan.html
