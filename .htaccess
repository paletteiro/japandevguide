Options -Indexes
ErrorDocument 404 /404.html
RewriteEngine On

# ─── Force HTTPS (http:// → https://) ──────────────────────────────────────
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# ─── Force non-www (www.japandevguide.com → japandevguide.com) ──────────────
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

# ─── Remove /index.html from homepage URL ───────────────────────────────────
RewriteCond %{THE_REQUEST} \s/index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]

# ─── Cache static assets ────────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg        "access plus 1 year"
  ExpiresByType image/webp        "access plus 1 year"
  ExpiresByType image/png         "access plus 1 year"
  ExpiresByType image/svg+xml     "access plus 1 year"
  ExpiresByType text/css          "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/html         "access plus 1 hour"
</IfModule>
<IfModule mod_headers.c>
  <FilesMatch "\.(jpg|jpeg|webp|png|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
    Header unset ETag
  </FilesMatch>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
  Header always set X-Content-Type-Options "nosniff"
</IfModule>
# Fallback: set cache via FileETag + mod_rewrite for hosts without mod_headers
FileETag None

# ─── Enable Gzip compression ────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript text/javascript application/json text/xml
</IfModule>

# ─── 301 Redirects: old Indonesian slugs → new English slugs ───────────────

RewriteRule ^articles/bahasa-jepang-untuk-engineer\.html$ /articles/japanese-for-engineers.html [R=301,L]
RewriteRule ^articles/biaya-hidup-jepang\.html$ /articles/cost-of-living-japan.html [R=301,L]
RewriteRule ^articles/budaya-kerja-it-jepang\.html$ /articles/it-work-culture-japan.html [R=301,L]
RewriteRule ^articles/cara-melamar-kerja-it-jepang\.html$ /articles/how-to-get-it-job-japan.html [R=301,L]
RewriteRule ^articles/gaji-it-jepang\.html$ /articles/it-salary-japan.html [R=301,L]
RewriteRule ^articles/interview-it-jepang\.html$ /articles/it-job-interview-japan.html [R=301,L]
RewriteRule ^articles/karir-it-jepang\.html$ /articles/it-career-japan.html [R=301,L]
RewriteRule ^articles/kelebihan-tinggal-di-jepang\.html$ /articles/why-live-in-japan-developer.html [R=301,L]
RewriteRule ^articles/tech-stack-jepang\.html$ /articles/tech-stack-japan.html [R=301,L]
RewriteRule ^articles/top-perusahaan-it-jepang\.html$ /articles/top-it-companies-japan.html [R=301,L]
RewriteRule ^articles/visa-kerja-jepang\.html$ /articles/it-work-visa-japan.html [R=301,L]
